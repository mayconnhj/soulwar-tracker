# ── Supabase (OBRIGATORIO) ──
# Pegue no Supabase Dashboard > Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...sua_service_role_key_aqui

# ── Vercel (frontend) ──
# Nao precisa mais do VITE_API_URL!
# As API routes rodam direto no Vercel via /api/*

# ── Local dev ──
# Copie este arquivo para .env e preencha as variaveis acima
